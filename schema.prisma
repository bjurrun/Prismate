generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String      @id
  email              String      @unique
  microsoftId        String?     @unique
  notesDirectoryPath String?
  createdAt          DateTime    @default(now())
  contacts           Contact[]
  projects           Project[]
  tasks              Task[]
  notes              Note[]
  files              File[]
  inboxItems         InboxItem[]
}

model Project {
  id          String   @id @default(cuid())
  microsoftId String?  @unique
  displayName String
  isShared    Boolean  @default(false)
  clerkUserId String
  createdAt   DateTime @default(now())
  deletedAt   DateTime?
  user        User     @relation(fields: [clerkUserId], references: [id])
  tasks       Task[]
  notes       Note[]
  files       File[]

  @@unique([clerkUserId, microsoftId], name: "clerkUserId_microsoftId")
}

model Task {
  id                       String          @id @default(cuid())
  microsoftId              String?         @unique
  title                    String
  body                     String?
  status                   String          @default("notStarted")
  importance               String          @default("normal")
  isImportant              Boolean         @default(false)
  isReminderOn             Boolean         @default(false)
  createdDateTime          DateTime        @default(now())
  lastModifiedDateTime     DateTime        @updatedAt
  startDateTime            DateTime?
  dueDateTime              DateTime?
  completedDateTime        DateTime?
  reminderDateTime         DateTime?
  recurrence               Json?
  categories               String[]        @default([])
  isMyDay                  Boolean         @default(false)
  isSomeday                Boolean         @default(false)
  myDayDate                DateTime?
  bodyLastModifiedDateTime DateTime?
  isFromEmail              Boolean         @default(false)
  webLink                  String?
  fromEmail                String?
  clerkUserId              String
  projectId                String?
  microsoftCalendarEventId String?         @unique
  attendees                Json?
  isTeamsMeeting           Boolean         @default(false)
  location                 String?
  deletedAt                DateTime?
  checklists               ChecklistItem[]
  user                     User            @relation(fields: [clerkUserId], references: [id])
  project                  Project?        @relation(fields: [projectId], references: [id])
  files                    File[]

  @@index([clerkUserId, isImportant, isMyDay])
}

model ChecklistItem {
  id          String  @id @default(cuid())
  title       String
  isCompleted Boolean @default(false)
  taskId      String
  task        Task    @relation(fields: [taskId], references: [id])
}

model Contact {
  id            String   @id @default(cuid())
  microsoftId   String?  @unique
  displayName   String
  givenName     String?
  surname       String?
  jobTitle      String?
  companyName   String?
  email         String?
  mobilePhone   String?
  businessPhone String?
  notes         String?
  clerkUserId   String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [clerkUserId], references: [id])
}

enum InboxItemType {
  EMAIL
  NOTE
  FILE
  OTHER
}

model InboxItem {
  id          String        @id @default(cuid())
  title       String
  type        InboxItemType @default(OTHER)
  content     String?
  sourceId    String?
  clerkUserId String
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?
  user        User          @relation(fields: [clerkUserId], references: [id])
}

model Note {
  id          String    @id @default(cuid())
  title       String
  content     String?
  projectId   String?
  clerkUserId String
  isPinned    Boolean   @default(false)
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  user        User      @relation(fields: [clerkUserId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  files       File[]
}

model File {
  id          String    @id @default(cuid())
  title       String
  url         String
  type        String
  projectId   String?
  taskId      String?
  noteId      String?
  clerkUserId String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  user        User      @relation(fields: [clerkUserId], references: [id])
  project     Project?  @relation(fields: [projectId], references: [id])
  task        Task?     @relation(fields: [taskId], references: [id])
  note        Note?     @relation(fields: [noteId], references: [id])
}
